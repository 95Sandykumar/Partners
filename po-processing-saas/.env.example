# ===========================================
# POFlow - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# --- Supabase ---
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Vision Provider (AI Extraction) ---
# Mode: hybrid (default) | deepseek | mistral
VISION_PROVIDER=hybrid

# DeepSeek OCR 2 (primary in hybrid mode)
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key
# Optional: self-hosted endpoint (overrides cloud API, zero per-page cost)
# DEEPSEEK_ENDPOINT=http://your-gpu-server:8000/v1/chat/completions

# Mistral OCR 3 (fallback in hybrid mode)
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key

# --- Stripe Billing ---
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Create products/prices in Stripe Dashboard, then copy price IDs here
STRIPE_STARTER_PRICE_ID=price_starter_id
STRIPE_PROFESSIONAL_PRICE_ID=price_professional_id
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_id

# --- Upstash Redis (distributed rate limiting) ---
# Get from: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (error tracking) ---
# Get from: https://sentry.io/settings/YOUR_ORG/projects/YOUR_PROJECT/keys/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# --- Logging ---
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# --- Email (optional, logs only if not configured) ---
# Install: npm install resend
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=POFlow <notifications@poflow.app>

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
